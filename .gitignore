# ===========================================
# Obsidian Vault .gitignore
# ===========================================

# Obsidian internal files
.obsidian/workspace*
.obsidian/cache
.obsidian/appearance.json
.obsidian/core-plugins.json
.obsidian/community-plugins.json
.obsidian/graph.json
.obsidian/backup/

# Plugin data (usually user-specific)
.obsidian/plugins/*/data.json

# OS generated files
.DS_Store
Thumbs.db
desktop.ini

# Logs and temporary files
*.log
*.tmp
*.swp
*~

# Optional: Uncomment if you want to ignore attachments
# attachments/

# Inbox processing files (large, temporary)
Inbox/*.json
Inbox/*.py
Inbox/*.log
._*
.trash/
